{
    "name": "ZCode",
    "category": "Desktop",
    "apiProtocol": [
        "openai",
        "anthropic"
    ],
    "docs": "https://zcode.z.ai/en/docs/welcome",
    "website": "https://zcode.z.ai/cn#all-downloads",
    "command": "",
    "configDir": "~/.zcode/v2",
    "configFile": "~/.zcode/v2/config.json",
    "requireConfigFile": false,
    "paths": {
        "win32": [
            "%LOCALAPPDATA%/Programs/ZCode/ZCode.exe"
        ],
        "darwin": [
            "/Applications/ZCode.app/Contents/MacOS/ZCode"
        ],
        "linux": [
            "/opt/ZCode/zcode",
            "~/.local/bin/zcode"
        ]
    },
    "installHints": {
        "windowsDisplayNamePrefixes": [
            "ZCode"
        ],
        "macosAppName": "ZCode"
    }
}
